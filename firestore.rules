rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helper Functions ==========

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // isAdmin: primero chequea custom claim, si no existe hace fallback al documento "usuarios"
    function isAdmin() {
      return isAuthenticated() && (
        // Preferir custom claim (más seguro, no expone datos)
        request.auth.token.admin == true
        ||
        // Fallback a lectura del documento usuarios (comprueba ambos nombres 'rol' y 'role')
        (
          exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin' ||
            get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin'
          )
        )
      );
    }

    // Proveedor/Supplier con soporte a 'rol' y 'role'
    function isSupplier() {
      return isAuthenticated() &&
             (
               // primero mirar si hay custom claim (más seguro)
               request.auth.token.supplier == true
               ||
               // fallback a documento usuarios (puede usar 'rol' o 'role')
               (
                 exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
                 (
                   get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'proveedor' ||
                   get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'proveedor'
                 )
               )
             );
    }

    // ========== Payouts Collection ==========
    match /payouts/{payoutId} {
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.status == 'scheduled';

      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    // ========== Usuarios Collection ==========
    match /usuarios/{userId} {
      // Lectura: dueño o admin
      allow read: if isOwner(userId) || isAdmin();

      // Crear: permitido para registro (sin auth) o si el uid coincide
      allow create: if true;

      // Actualizar / Eliminar: solo dueño o admin
      allow update, delete: if isOwner(userId) || isAdmin();

      // Subcolección de transacciones
      match /transactions/{txId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Subcolección de documentos (cédula, RUT, certificación bancaria)
      match /documentos/{docType} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ========== Inventory Collection ==========
    match /inventory/{docId} {
      // Sólo admins pueden leer/escribir inventory
      allow read, write: if isAdmin();
    }

    // Historial de inventario (si lo tienes separado)
    match /inventoryHistory/{docId} {
      allow read, write: if isAdmin();
    }

    // ========== Distribuidores Collection ==========
    match /distribuidores/{docId} {
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // ========== Orders Collection ==========
    match /orders/{orderId} {
      // Allow create if:
      // 1. User is authenticated AND is the buyer (normal purchase flow), OR
      // 2. User is an admin creating an order on behalf of a distributor (admin-generated orders)
      allow create: if isAuthenticated()
                    && (
                      request.auth.uid == request.resource.data.buyerUid ||
                      (isAdmin() && request.resource.data.createdByAdmin == true)
                    );

      // lectura del dueño de la orden, admins o proveedores
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.buyerUid || isAdmin() || isSupplier());

      // actualización por parte del dueño de la orden (ej. cancelar)
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.buyerUid || isAdmin() || isSupplier());
    }

    // ========== Users Collection (alternativa si la usas) ==========
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /transactions/{txId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Subcolección de documentos (cédula, RUT, certificación bancaria)
      match /documentos/{docType} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ========== Productos Collection ==========
    match /productos/{productId} {
      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    // ========== Categorias Collection ==========
    match /categorias/{categoriaId} {
      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    // ========== Inversiones Collection ==========
    match /inversiones/{inversionId} {
      // Public read - investments are displayed in virtual office
      allow read: if true;

      // Only admins can create, update, or delete investments
      allow create, update, delete: if isAdmin();
    }

    // ========== Commissions Purged Collection (Admin Reports) ==========
    match /commissionsPurged/{reportId} {
      // Only admins can read purge reports
      allow read: if isAdmin();

      // Only server-side functions should write (no client writes)
      allow create, update, delete: if false;
    }

    // ========== Config Collection (Promo Codes, Settings, etc.) ==========
    match /config/{configId} {
      // Admins can read and write config documents (promo codes, etc.)
      allow read, write: if isAdmin();
    }

    // ========== Purge Audit Log Collection (Internal Audit Trail) ==========
    match /purgeAuditLog/{logId} {
      // Only admins can read audit logs
      allow read: if isAdmin();

      // Only server-side functions should write (no client writes)
      allow create, update, delete: if false;
    }

    // ========== Educacion Collection (Education Content) ==========
    match /educacion/{educacionId} {
      // Public read - education content is displayed in virtual office
      allow read: if true;

      // Only admins can create, update, or delete education content
      allow create, update, delete: if isAdmin();
    }

    // ========== Activity Logs Collection (Admin Activity Feed) ==========
    match /activity_logs/{logId} {
      // Only admins can read activity logs
      allow read: if isAdmin();

      // Admins can create activity logs from admin panel
      allow create: if isAdmin();

      allow update, delete: if false;
    }

    // ========== Admin Sales Collection (Ventas generadas por admin) ==========
    match /admin_sales/{saleId} {
      // Admins can read all sales, distributors/restaurants can read their own
      allow read: if isAdmin() || (isAuthenticated() && resource.data.distributorId == request.auth.uid);

      // Only admins can create sales
      allow create: if isAdmin();

      // Only admins can update (e.g., cancel/modify)
      allow update: if isAdmin();

      // No deletes allowed
      allow delete: if false;
    }

    // ========== Game Income Logs Collection ==========
    match /game_income_logs/{logId} {
      // Only admins can read game income logs
      allow read: if isAdmin();

      // Only server-side functions should write (no client writes)
      allow create, update, delete: if false;
    }

    // ========== Game Purchases Collection ==========
    match /game_purchases/{purchaseId} {
      // Users can read their own purchases, admins can read all
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);

      // Only server-side functions should write
      allow create, update, delete: if false;
    }

    // ========== Game Achievements Collection ==========
    match /game_achievements/{achievementId} {
      // Users can read their own achievements, admins can read all
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);

      // Only server-side functions should write
      allow create, update, delete: if false;
    }

    // ========== Game Orders Collection ==========
    match /game_orders/{orderId} {
      // Users can read their own orders, admins can read all
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);

      // Only server-side functions should write
      allow create, update, delete: if false;
    }

    // ========== Game Payments Collection ==========
    match /game_payments/{paymentId} {
      // Users can read their own payments, admins can read all
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);

      // Only server-side functions should write
      allow create, update, delete: if false;
    }

    // ========== Monthly Earnings Closures Collection ==========
    match /monthlyEarningsClosures/{closureId} {
      // Only admins can read monthly earnings closures
      allow read: if isAdmin();

      // Only admins can create, update monthly closures
      allow create, update: if isAdmin();

      // Only admins can delete (rare operation)
      allow delete: if isAdmin();
    }
  }
}
